    },
    "definitions": {
        "handler.errorBody": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "handler.messageBody": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "handler.teamsListBody": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/usecase.TeamResponse"
                    }
                }
            }
        },
        "usecase.CreateTeamRequest": {
            "type": "object",
            "required": [
                "teamName"
            ],
            "properties": {
                "teamName": {
                    "type": "string"
                }
            }
        },
        "usecase.TeamActionRequest": {
            "type": "object",
            "required": [
                "userId"
            ],
            "properties": {
                "userId": {
                    "type": "integer"
                }
            }
        },
        "usecase.TeamResponse": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "mainManagerUserId": {
                    "type": "integer"
                },
                "managers": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "members": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "teamId": {
                    "type": "integer"
                },
                "teamName": {
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Bearer token issued by Auth service (include the word Bearer, a space, then the JWT)",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}